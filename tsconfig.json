{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./resources/js/*"],
      "@AdminComponents/*": ["./resources/js/Components/Admin/*"],
      "@GuestComponents/*": ["./resources/js/Components/Guest/*"]
    }
  },
  "include": ["resources/js/**/*"],
  "exclude": ["node_modules", "public"]
}
